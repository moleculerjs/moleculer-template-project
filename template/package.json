{
  "name": "{{projectName}}",
  "version": "1.0.0",
  "description": "My Moleculer-based microservices project",
  "scripts": {
    "dev": "moleculer-runner --repl --hot services/**/*.service.js",
    "start": "moleculer-runner",
    "cli": "moleculer connect {{transporter}}",
    "ci": "jest --watch",
    "test": "jest --coverage"{{#lint}},
    "lint": "eslint services"{{/lint}}{{#docker}},
    "dc:up": "docker compose up --build -d",
    "dc:logs": "docker compose logs -f",
    "dc:down": "docker compose down"{{/docker}}
  },
  "keywords": [
    "microservices",
    "moleculer"
  ],
  "author": "",
  "devDependencies": {
    {{#lint}}
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "prettier": "^3.5.3",
    {{/lint}}
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    {{#apiGW}}
    "supertest": "^7.1.1",
    {{/apiGW}}
    {{#apiIO}}
    "socket.io-client": "^4.8.1",
    {{/apiIO}}
    {{#apiGQL}}
    "graphql-request": "^6.1.0",
    {{/apiGQL}}
    "moleculer-repl": "^0.7.4"
  },
  "dependencies": {
    {{#apiGW}}
    "moleculer-web": "^0.10.8",
    {{/apiGW}}
    {{#dbService}}
    "@moleculer/database": "^0.3.0",
    "mongodb": "^6.16.0",
    "nedb": "^1.8.0",
    {{/dbService}}
    {{#nats}}
    "nats": "^2.29.3",
    {{/nats}}
    {{#if_eq transporter "MQTT"}}
    "mqtt": "^5.13.0",
    {{/if_eq}}
    {{#rabbitmq}}
    "amqplib": "^0.10.8",
    {{/rabbitmq}}
    {{#if_eq transporter "AMQP10"}}
    "rhea-promise": "^3.0.3",
    {{/if_eq}}
    {{#kafka}}
    "kafkajs": "^2.2.4",
    {{/kafka}}
    {{#redis}}
    "ioredis": "^5.6.1",
    {{/redis}}
    {{#apiGQL}}
    "graphql": "^15.10.0",
    "moleculer-apollo-server": "^0.3.8",
    "graphql-type-json": "^0.3.2",
    {{/apiGQL}}
    {{#needChannels}}
    "@moleculer/channels": "^0.2.0",
    {{/needChannels}}
    {{#apiIO}}
    "moleculer-io": "^2.0.0",
    {{/apiIO}}
    "moleculer": "^0.15.0-beta1"
  },
  {{#apiGQL}}
  "overrides": {
    "@graphql-tools/links@7": {
      "apollo-upload-client": "15.0.0"
    },
    "@graphql-tools/url-loader@6": {
      "extract-files": "10.0.0"
    },
    "graphql-request": {
      "extract-files": "10.0.0"
    },
    "apollo-upload-client": {
      "extract-files": "10.0.0"
    }
  },{{/apiGQL}}
  "engines": {
    "node": ">= 20.x.x"
  },
  "jest": {
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "rootDir": "./services",
    "roots": [
      "../test"
    ]
  }
}
